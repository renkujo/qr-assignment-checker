# Public HTTPS URL for the SvelteKit app, used by @sveltejs/adapter-node.
APP_ORIGIN=https://qr-assignment-checker.example.com
ORIGIN=https://qr-assignment-checker.example.com

# Server-side PocketBase URL. In Docker/Haabiz internal networking, prefer the service name.
POCKETBASE_URL=http://pocketbase:8090

# Public PocketBase HTTPS URL. Use this for PocketBase Admin UI and any browser-side SDK use.
PUBLIC_POCKETBASE_URL=https://qr-assignment-pocketbase.example.com

# PocketBase binary version used by Dockerfile.pocketbase.
PB_VERSION=0.39.5
